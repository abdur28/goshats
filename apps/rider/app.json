{
  "expo": {
    "name": "GO SHATS Rider",
    "slug": "goshats-rider",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icons/icon.png",
    "scheme": "goshats-rider",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.goshats.rider",
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {},
      "icon": {
        "dark": "./assets/icons/Dark.png",
        "light": "./assets/icons/Light.png",
        "tinted": "./assets/icons/Tinted.png"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.goshats.rider",
      "config": {},
      "adaptiveIcon": {
        "backgroundColor": "#264834",
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "monochromeImage": "./assets/icons/adaptive-icon.png"
      }
    },
    "web": {
      "output": "static",
      "bundler": "metro",
      "favicon": "./assets/icons/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://goshats-rider.expo.app/"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#264834"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow GO SHATS Rider to use your location to broadcast your position during deliveries.",
          "locationAlwaysAndWhenInUsePermission": "Allow GO SHATS Rider to always use your location so your position can be broadcast to customers during active deliveries, even when the app is in the background.",
          "locationAlwaysPermission": "Allow GO SHATS Rider to always use your location so your position can be broadcast to customers during active deliveries, even when the app is in the background.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/icon.png",
          "color": "#264834"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GO SHATS Rider to access your photo library to update your profile picture."
        }
      ],
      ["expo-document-picker", {}],
      "react-native-maps",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://goshats.expo.app/"
      },
      "eas": {
        "projectId": "f65a3f70-ceae-41ce-b687-fa3beb148b93"
      }
    }
  }
}
