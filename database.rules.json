{
  "rules": {
    ".read": false,
    ".write": false,

    "status": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.hasChildren(['state', 'lastChanged'])",

        "state": {
          ".validate": "newData.isString() && (newData.val() === 'online' || newData.val() === 'offline')"
        },

        "lastChanged": {
          ".validate": "newData.isNumber()"
        },

        "$other": {
          ".validate": false
        }
      }
    }
  }
}
